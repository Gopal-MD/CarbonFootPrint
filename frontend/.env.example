# ──────────────────────────────────────────────────────────────
# Frontend environment variables — copy to .env.local
# These are the Firebase CLIENT config (safe to expose in browser)
# ──────────────────────────────────────────────────────────────

# Firebase Project Config
# Get from: Firebase Console > Project Settings > Your apps > Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# Google Maps API (client-side, loaded via JS API Loader)
VITE_GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# Development options
# Set to 'true' to use Firebase Local Emulator Suite
VITE_USE_FIREBASE_EMULATOR=false
