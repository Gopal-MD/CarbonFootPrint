# ────────────────────────────────────────────────────────────────
# Backend environment variables — copy this to .env and fill in
# NEVER commit .env to version control
# ────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ── Google Gemini API ─────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Maps API ───────────────────────────────────────────
# Enable: Directions API, Maps JavaScript API
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# ── Google Cloud Vision API ───────────────────────────────────
# Enable: Cloud Vision API
GOOGLE_CLOUD_PROJECT_ID=your_project_id_here

# ── Firebase Admin SDK ────────────────────────────────────────
# Download from: Firebase Console > Project Settings > Service Accounts
# Option 1: Inline JSON (recommended for Cloud Run secrets)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option 2: Path to file (for local dev)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ── Frontend Firebase Config (also needed for Admin validation) ──
VITE_FIREBASE_PROJECT_ID=your_project_id_here

# ── Security ──────────────────────────────────────────────────
# CORS: comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Feature Flags ─────────────────────────────────────────────
# Set to 'true' to use stub responses instead of real APIs (for testing)
MAPS_STUB=false
GEMINI_STUB=false
VISION_STUB=false
